# Copy this file to `.env.local`, `.env.dev.local`, or `.env.final.local`.
# These files are ignored by git and auto-loaded by `main.py`.

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low

# Optional: Hugging Face semantic reranking for final article selection.
# HF_SEMANTIC_RERANK_ENABLED=true
# HF_TOKEN=
# HF_SEMANTIC_MODEL=intfloat/multilingual-e5-large

KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REFRESH_TOKEN=

# Optional: GA4 tracking on generated pages.
GA4_MEASUREMENT_ID=
GA4_DEBUG_MODE=false

# Optional: GA4 admin dashboard export and custom-dimension registration.
GA4_PROPERTY_ID=
# Recommended: point to a local service-account JSON file kept under `.secrets/`.
# Example: GA4_SERVICE_ACCOUNT_FILE=.secrets/ga4-service-account.json
GA4_SERVICE_ACCOUNT_FILE=
# Alternative: paste the full JSON on one line only if you really need it.
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional fallback if you manage short-lived tokens externally.
# GA4_ACCESS_TOKEN=

# Optional overrides for local publish scripts.
# GH_TOKEN=
# GITHUB_REPO=NH-Horti/agri-news-brief
